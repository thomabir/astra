<!DOCTYPE html>
<html lang="en">
<head>
    <title>Astra</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.plot.ly/plotly-2.20.0.min.js" charset="utf-8"></script>
    <link rel="icon" href="favicon.svg">
</head>
<body class="bg-black text-slate-100 select-none w-full h-full ">
    {% set navigation = ['Summary', 'Log', 'Weather', 'Controls'] %}

    <div id="popup" class="absolute hidden rounded-md p-2 shadow-md bg-black/90 text-sm opacity-90 whitespace-break-spaces z-10"></div>
    <div id="popup_imageinfo" class="absolute hidden rounded-md p-2 shadow-md bg-black/90 text-sm opacity-90 whitespace-break-spaces z-10"></div>


    <div class="flex flex-wrap h-screen items-center justify-center">
        {% for observatory in observatories %}
        <div id="{{ observatory }}" class="flex flex-col 
        w-[100%] h-[calc(90vw*5/3)] 
        md:w-[50%] md:h-[calc(45vw*5/3)] 
        lg:w-[40%] lg:h-[calc(36vw*5/3)] 
        xl:w-[33%] xl:h-[calc(30vw*5/3)] 
        2xl:w-[22%] 2xl:h-[calc(20vw*5/3)] 
        m-4 p-4 space-y-4 bg-white/10 shadow-slate-950/50 shadow-xl rounded-xl">
            
            {# title #}
            <div class="flex flex-row flex-initial text-3xl font-bold align-bottom">
                <div class="flex-initial justify-left">
                    <div id="title-{{ observatory }}">
                        {{ observatory }}
                    </div>
                </div>

                <div class="grow">
                    <div class="flex flex-row-reverse h-full items-center">
                        <div title="Abort!">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-red-700 active:text-red-600 cursor-pointer" onclick="interrupt('{{observatory}}')" title="This is your tooltip">
                                <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm6-2.438c0-.724.588-1.312 1.313-1.312h4.874c.725 0 1.313.588 1.313 1.313v4.874c0 .725-.588 1.313-1.313 1.313H9.564a1.312 1.312 0 01-1.313-1.313V9.564z" clip-rule="evenodd" />
                            </svg>
                        </div>

                        <div title="Start watchdog">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 mr-2 text-green-700 active:text-green-600 cursor-pointer" onclick="startWatchdog('{{observatory}}')">
                                <path fill-rule="evenodd" d="M9.315 7.584C12.195 3.883 16.695 1.5 21.75 1.5a.75.75 0 01.75.75c0 5.056-2.383 9.555-6.084 12.436A6.75 6.75 0 019.75 22.5a.75.75 0 01-.75-.75v-4.131A15.838 15.838 0 016.382 15H2.25a.75.75 0 01-.75-.75 6.75 6.75 0 017.815-6.666zM15 6.75a2.25 2.25 0 100 4.5 2.25 2.25 0 000-4.5z" clip-rule="evenodd" />
                                <path d="M5.26 17.242a.75.75 0 10-.897-1.203 5.243 5.243 0 00-2.05 5.022.75.75 0 00.625.627 5.243 5.243 0 005.022-2.051.75.75 0 10-1.202-.897 3.744 3.744 0 01-3.008 1.51c0-1.23.592-2.323 1.51-3.008z" />
                            </svg>
                        </div>
                    </div>
                </div>

            </div>
                
            {# nav #}
            <div class="flex-initial">
                <nav class="flex flex-wrap justify-between">
                    {% for nav in navigation %}
                        <div id="{{nav | lower}}-{{ observatory }}" 
                            class="flex-initial p-2 text-center hover:text-slate-200 cursor-pointer {{ 'underline' if loop.first else '' }}" 
                            onclick="navClick(this)">
                        {{ nav }}
                        </div>
                    {% endfor %}
                </nav>
            </div>

            {# content #}
            <div id="content-{{ observatory }}" class="flex-initial justify-center font-light overflow-auto">
                {% for nav in navigation %}
                    <div id="{{nav | lower}}-content-{{ observatory }}" class="{{ '' if loop.first else 'hidden' }} w-full space-y-4 flex flex-col h-full">
                        {% if nav == 'Summary'%}
                        {# move table to macro? #}

                            <table id="summary-table-0-{{ observatory }}" class="text-left w-full table-auto rounded-lg bg-gray-600/20">
                                <thead>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>

                            <table id="summary-table-1-{{ observatory }}" class="text-left w-full table-auto rounded-lg bg-gray-600/20">
                                <thead>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                            
                            <div class="flex flex-row justify-center items-center">
                            {# lastest image #}
                                <div id="summary-last-image-parent-{{ observatory }}" class="flex justify-center basis-1/2 mr-2">
                                        <img id="summary-last-image-{{ observatory }}" alt="lastest image" class="object-contain h-full w-full hidden">
                                        <svg xmlns="http://www.w3.org/2000/svg" id="summary-last-image-placeholder-{{ observatory }}" viewBox="0 0 24 24" fill="currentColor" class="w-full p-12 opacity-20">
                                            <path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 012.25-2.25h16.5A2.25 2.25 0 0122.5 6v12a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 18V6zM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0021 18v-1.94l-2.69-2.689a1.5 1.5 0 00-2.12 0l-.88.879.97.97a.75.75 0 11-1.06 1.06l-5.16-5.159a1.5 1.5 0 00-2.12 0L3 16.061zm10.125-7.81a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0z" clip-rule="evenodd" />
                                        </svg>
                                </div>

                            {# webcam feed #}
                                <div class="basis-1/2 ml-2 ">
                                    {% if webcamfeeds != {} %}
                                        webcam
                                        {# <img src="{{ webcamfeeds[observatory]['rtsp'] }}" alt="webcam placeholder image" class="object-contain h-full w-full"> #}
                                    {% endif %}
                                </div>
                            </div>

                        {% elif nav == 'Log' %}
                            
                            <div class="flex flex-col space-y-4 h-full">

                                <div class="flex-none basis-1/4 overflow-auto">
                                    {# <span class="my-4">schedule</span> #}
                                    <table id="schedule-table-0-{{ observatory }}" class="text-left w-full table-auto rounded-lg bg-gray-600/20">
                                        <thead>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>

                                <div id="log-0-{{ observatory }}" class="basis-3/4 text-left w-full text-sm rounded-lg bg-gray-600/20 overflow-y-scroll overflow-x-clip">
                                </div>
                        
                            </div>

                        {% elif nav == 'Weather' %}
                            
                            <div class="flex-none flex flex-col h-full">
                                <div id="weather-chart-{{observatory}}"></div>
                            </div>
                            

                            {# windy map/forecast #}
                            {# <iframe class="w-full basis-1/2 rounded-lg opacity-90"
                            src="https://embed.windy.com/embed2.html?lat=-24.755&lon=-70.406&detailLat=-24.699&detailLon=-70.406&width=650&height=450&zoom=11&level=700h&overlay=clouds&product=ecmwf&menu=&message=true&marker=true&calendar=now&pressure=&type=map&location=coordinates&detail=&metricWind=km%2Fh&metricTemp=%C2%B0C&radarRange=-1"
                            frameborder="0"></iframe> #}

                        {% elif nav == 'Controls' %}
                            <div class="flex flex-col flex-grow place-content-center items-center max-h-full my-auto">
                                <div class="my-4">
                                    <button type="button" class="focus:outline-none text-white w-full bg-green-700 hover:bg-green-800 focus:ring-4 focus:ring-green-300 font-medium rounded-lg text-sm px-5 py-2.5 mb-4 dark:bg-green-600 dark:hover:bg-green-700 dark:focus:ring-green-800" onclick="startWatchdog('{{observatory}}')">Start watchdog</button>
                                                                
                                    <button type="button" class="focus:outline-none text-white w-full bg-orange-700 hover:bg-orange-800 focus:ring-4 focus:ring-orange-300 font-medium rounded-lg text-sm px-5 py-2.5 mb-4 dark:bg-orange-600 dark:hover:bg-orange-700 dark:focus:ring-orange-900" onclick="stopWatchdog('{{observatory}}')">Stop watchdog</button>

                                    <button type="button" class="focus:outline-none text-white w-full bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 mb-4 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900" onclick="interrupt('{{observatory}}')">ABORT</button>
                                </div>
                            </div>
                            
            
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
    </div>

    <script>

        const popup = document.querySelector('#popup');
        const popup_imageinfo = document.querySelector('#popup_imageinfo');
        let scheduleLoadTime = {}

        let mouseoverFunc = (data) => {
            return (e) => {
                popup_imageinfo.classList.remove('hidden');
                popup_imageinfo.classList.add('block');
                popup_imageinfo.innerHTML = syntaxHighlight(data);
                movePopupImageInfo(e);
            };
        };

        let mousemoveFunc = (e) => {
            movePopupImageInfo(e);
        };

        let mouseoutFunc = () => {
            popup_imageinfo.classList.remove('block');
            popup_imageinfo.classList.add('hidden');
        };

        let clickFunc = () => {
            // toggle
            if (popup_imageinfo.classList.contains('hidden')) {
                popup_imageinfo.classList.remove('hidden');
                popup_imageinfo.classList.add('block');
            } else {
                popup_imageinfo.classList.remove('block');
                popup_imageinfo.classList.add('hidden');
            }
        };

        function movePopup(e) {
            const mouseX = e.pageX;
            const mouseY = e.pageY;
            const popupWidth = popup.offsetWidth;
            const popupHeight = popup.offsetHeight;
            const padding = 10;
            const popupX = mouseX + padding;
            const popupY = mouseY + padding;
            const maxX = window.innerWidth - popupWidth - padding;
            // const maxY = window.innerHeight - popupHeight - padding;
            const adjustedX = Math.min(popupX, maxX);
            // const adjustedY = Math.min(popupY, maxY);
            popup.style.left = `${adjustedX}px`;
            popup.style.top = `${popupY}px`;
        }

        function movePopupImageInfo(e) {
            const mouseX = e.pageX;
            const mouseY = e.pageY;
            const popupWidth = popup_imageinfo.offsetWidth;
            const popupHeight = popup_imageinfo.offsetHeight;
            const padding = 10;
            const popupX = mouseX + padding;
            const popupY = mouseY + padding;
            const maxX = window.innerWidth - popupWidth - padding;
            // const maxY = window.innerHeight - popupHeight - padding;
            const adjustedX = Math.min(popupX, maxX);
            // const adjustedY = Math.min(popupY, maxY);
            popup_imageinfo.style.left = `${adjustedX}px`;
            popup_imageinfo.style.top = `${popupY}px`;
        }
        
        function syntaxHighlight(json) {
            if (typeof json != 'string') {
                json = JSON.stringify(json, undefined, 2);
            }
            json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
                var cls = 'number';
                if (/^"/.test(match)) {
                    if (/:$/.test(match)) {
                        cls = 'key';
                    } else {
                        cls = 'string';
                    }
                } else if (/true|false/.test(match)) {
                    cls = 'boolean';
                } else if (/null/.test(match)) {
                    cls = 'null';
                }
                return '<span class="' + cls + '">' + match + '</span>';
            });
        }
   
        function navClick(element) {
            // element: the navigation element that was clicked

            // remove underline from other elements
            {% for nav in navigation %}
                document.getElementById("{{nav | lower}}-" + element.id.split("-")[1]).classList.remove("underline")
            {% endfor %}
            // underline the clicked element
            document.getElementById(element.id).classList.add("underline")

            // hide all content
            {% for nav in navigation %}
                document.getElementById("{{nav | lower}}-content-" + element.id.split("-")[1]).classList.add("hidden")
            {% endfor %}

            // show the content for the clicked element
            document.getElementById(element.id.split("-")[0] + "-content-" + element.id.split("-")[1]).classList.remove("hidden")

            let div = document.getElementById("content-" + element.id.split("-")[1])
            if (element.id.split("-")[0] == 'log') {
                let divLog = document.getElementById("log-0-" + element.id.split("-")[1])
                divLog.scrollTop = divLog.scrollHeight;
            } else {
                div.scrollTop = 0;
            }

            
        }

        function updateTable(tableId, data, headers, thead_display=true, right_align=true) {
            // tableId: id of the table to update
            // data: array of objects containing the data to be displayed
            // headers: object containing the headers for the table
            // thead_display: boolean, whether to display the table headers

            var table = document.getElementById(tableId);


            if (thead_display) {
                var thead = table.getElementsByTagName("thead")[0];
                thead.innerHTML = "";

                var row = thead.insertRow(0);
                row.classList.add("border-b-2");
                row.classList.add("border-b-slate-500");

                for (var i = 0; i < Object.keys(headers).length; i++) {
                    var cell = row.insertCell(i);
                    cell.innerHTML = Object.values(headers)[i];
                    cell.classList.add("py-1.5");
                    cell.classList.add("px-3");

                    // if last column, right align
                    if ((i == Object.keys(headers).length - 1) && right_align) {
                        cell.classList.add("text-right");
                    }
                }
            }

            var tbody = table.getElementsByTagName("tbody")[0];
            tbody.innerHTML = "";

            // create a new row for every item in data
            for (var i = 0; i < data.length; i++) {
                var row = tbody.insertRow(i);
                row.classList.add("border-b");
                row.classList.add("border-b-slate-500");
                row.key = i;


                row.addEventListener('mouseover', (e) => {
                    popup.classList.remove('hidden');
                    popup.classList.add('block');
                    popup.innerHTML = syntaxHighlight(data[e.target.parentNode.key]);
                    movePopup(e);
                });

                row.addEventListener('mousemove', (e) => {
                    movePopup(e);
                });

                row.addEventListener('mouseout', () => {
                    popup.classList.remove('block');
                    popup.classList.add('hidden');

                });

                row.addEventListener('click', (e) => {
                    // toggle
                    console.log("clicked")
                    if (popup.classList.contains('hidden')) {
                        popup.classList.remove('hidden');
                        popup.classList.add('block');
                    } else {
                        popup.classList.remove('block');
                        popup.classList.add('hidden');
                    }
                });

                for (var j = 0; j < Object.keys(headers).length; j++) {
                    var cell = row.insertCell(j);
                    cell.innerHTML = data[i][Object.keys(headers)[j]];
                    cell.classList.add("py-1.5");
                    cell.classList.add("px-3");


                    // if last column, right align and blue text
                    if ((j == Object.keys(headers).length - 1) && right_align) {
                        cell.classList.add("text-right");
                        cell.classList.add("text-blue-300");
                        cell.classList.add("font-variant-numeric");
                        cell.classList.add("proportional-nums");
                    }

                    // if status column, colour the cell
                    if (Object.keys(headers)[j] == "status") {
                        if (data[i]['valid'] == true) {
                            cell.classList.add("text-green-500");
                        } else if (data[i]['valid'] == false) {
                            cell.classList.add("text-red-500");
                        }
                    }
                }
                
            }
            row.classList.remove("border-b");
            row.classList.remove("border-b-slate-500");

        }
     
        function updateSchedule(observatory) {

            fetch('/api/schedule/' + observatory)
                .then(response => response.json())
                .then(data => {
                    updateTable("schedule-table-0-" + observatory, data, {"action_type": "action", "start_HHMMSS": "start", "end_HHMMSS": "end"}, true, false);
                });

        }

        function updateWeatherChart(observatory, update=false) {

            fetch('/api/db/polling/' + observatory + '/ObservingConditions')
                .then(response => response.json())
                .then(data => {
                    
                    let graphData = [];
                    let titles = {};
                    let yaxisRanges = {};

                    Object.keys(data).forEach((deviceCommand) => {

                        let trace = {
                                x: Object.keys(data[deviceCommand]),
                                y: Object.values(data[deviceCommand]),
                                type: 'scatter',
                                mode: 'markers',
                                showlegend: false,
                                name: deviceCommand,
                                yaxis: 'y' + (Object.keys(data).indexOf(deviceCommand) + 1),
                            };

                        titles['yaxis' + (Object.keys(data).indexOf(deviceCommand) + 1)] = {
                                title: deviceCommand,
                            }

                        // Set yaxis limits based on deviceCommand
                        yaxisRanges[deviceCommand] = {
                            min: Math.min(...Object.values(data[deviceCommand])) - 1,
                            max: Math.max(...Object.values(data[deviceCommand])) + 1,
                        };

                        if (deviceCommand == 'Temperature') {
                            yaxisRanges[deviceCommand].min = -10;
                            yaxisRanges[deviceCommand].max = 50;
                        } else if (deviceCommand == 'Humidity') {
                            yaxisRanges[deviceCommand].min = 0;
                            yaxisRanges[deviceCommand].max = 100;
                        } else if (deviceCommand == 'SkyTemperature') {
                            yaxisRanges[deviceCommand].min = -60;
                            yaxisRanges[deviceCommand].max = 0;
                        } else if (deviceCommand == 'WindSpeed') {
                            yaxisRanges[deviceCommand].min = 0;
                            yaxisRanges[deviceCommand].max = 100;
                        } else if (deviceCommand == 'DewPoint') {
                            yaxisRanges[deviceCommand].min = -50;
                            yaxisRanges[deviceCommand].max = 50;
                        }


                        trace.yaxis.range = [yaxisRanges[deviceCommand].min, yaxisRanges[deviceCommand].max];

                        graphData.push(trace);
                    
                    });

                    let elp = document.getElementById(observatory);
                    let positionInfo = elp.getBoundingClientRect();

                    let layout_0 = {
                        grid: {
                            rows:  Object.keys(data).length,
                            columns: 1,
                        },
                        margin: {l: 50, r: 15, b: 70, t: 20},
                        paper_bgcolor: 'rgba(0,0,0,0)', // sets background color
                        plot_bgcolor: 'rgb(36,38,41)', // sets plot area color
                        font: {
                            color: 'rgb(242,245,249)' // sets font color
                        },
                        width: positionInfo.width - 50,
                        height: positionInfo.height - 50,
                    };

                    let layout = {
                        ...layout_0,
                        ...titles
                    }

                    // Set yaxis limits based on deviceCommand
                    Object.keys(yaxisRanges).forEach((deviceCommand) => {
                        layout['yaxis' + (Object.keys(data).indexOf(deviceCommand) + 1)].range = [yaxisRanges[deviceCommand].min, yaxisRanges[deviceCommand].max];
                    });

                    let config = {
                        responsive: true,
                        displayModeBar: false,
                    };

                    if (update == false ){
                        Plotly.newPlot('weather-chart-' + observatory, graphData, layout, config);
                    } else {
                        Plotly.react('weather-chart-' + observatory, graphData, layout, config);
                    }

                });

        }

        function startWatchdog(observatory) {
            if (confirm("Are you sure you want to start the watchdog?")) {
                fetch('/api/startwatchdog/' + observatory)
                    .then(response => response.json())
                    .then(data => {
                            console.log(data);
                    });
            }
        }
        
        function stopWatchdog(observatory) {
            if (confirm("Are you sure you want to stop the watchdog?")) {
                fetch('/api/stopwatchdog/' + observatory)
                    .then(response => response.json())
                    .then(data => {
                            console.log(data);
                    });
            }
        }

        function interrupt(observatory) {
            if (confirm("Are you sure you want to abort current actions?")) {
                fetch('/api/interrupt/' + observatory)
                    .then(response => response.json())
                    .then(data => {
                            console.log(data);
                    });
            }
        }

        function connectWebSocket(url, observatory, type) {
            let socket = new WebSocket(url);

            socket.onopen = function() {
                console.log('WebSocket connection established.');
                // Perform any necessary actions upon successful connection.
            };

            socket.onclose = function(event) {
                console.log('WebSocket connection closed:', event);
                // Handle the closure, initiate reconnection logic.
                reconnectWebSocket(url, observatory, type);
            };

            socket.onmessage = function(event) {
                onMessageFunc(observatory, type, event);
                // Process incoming messages.
            };

            socket.onerror = function(error) {
                console.log('WebSocket error:', error);
                // Handle any errors that occur.
                alert('WebSocket error see browser console');
            };

            return socket;
        }

        function reconnectWebSocket(url, observatory, type) {
            // Wait for a certain time before attempting reconnection.
            setTimeout(function() {
                connectWebSocket(url, observatory, type);
            }, 3000); // You can adjust the time interval between reconnection attempts.
        }

        function onMessageFunc(observatory, type, event) {
            let message = JSON.parse(event.data);
            if (type == 'summary') {
                updateTable("summary-table-0-" + observatory, message['table0'], {"item": "item", "status": "status", "last_update": "last update"});

                // update title color if error found in astra
                if (message['table1'][0]['item'] == "error free"){
                    if (message['table1'][0]['value'] == false) {
                        document.getElementById("title-" + observatory).classList.add('text-red-500');
                    } else {
                        document.getElementById("title-" + observatory).classList.remove('text-red-500');
                    }
                }

                // remove first item of table1, error free status
                message['table1'].shift();
                updateTable("summary-table-1-" + observatory, message['table1'], {"item": "item", "value": "value"}, false);

                // update last image
                let lastImageDiv = document.getElementById("summary-last-image-parent-" + observatory);
                let lastImage = message['last_image'];
                if (lastImage['url'] != null) {
                    document.getElementById("summary-last-image-" + observatory).classList.remove('hidden');
                    document.getElementById("summary-last-image-placeholder-" + observatory).classList.add('hidden');
                    document.getElementById("summary-last-image-" + observatory).src = lastImage['url'];

                    popup_imageinfo.innerHTML = syntaxHighlight(lastImage['useful_headers']);

                    // Remove old event listeners
                    lastImageDiv.removeEventListener('mouseover', mouseoverFunc(lastImage['useful_headers']));
                    lastImageDiv.removeEventListener('mousemove', mousemoveFunc);
                    lastImageDiv.removeEventListener('mouseout', mouseoutFunc);
                    lastImageDiv.removeEventListener('click', clickFunc);

                    // Add new event listeners
                    lastImageDiv.addEventListener('mouseover', mouseoverFunc(lastImage['useful_headers']));
                    lastImageDiv.addEventListener('mousemove', mousemoveFunc);
                    lastImageDiv.addEventListener('mouseout', mouseoutFunc);
                    lastImageDiv.addEventListener('click', clickFunc);
                } else {
                    document.getElementById("summary-last-image-" + observatory).classList.add('hidden');
                    document.getElementById("summary-last-image-placeholder-" + observatory).classList.remove('hidden');

                    popup_imageinfo.innerHTML = syntaxHighlight({'image': 'no image found'});

                    // Remove old event listeners
                    lastImageDiv.removeEventListener('mouseover', mouseoverFunc({'image': 'no image found'}));
                    lastImageDiv.removeEventListener('mousemove', mousemoveFunc);
                    lastImageDiv.removeEventListener('mouseout', mouseoutFunc);

                    // Add new event listeners
                    lastImageDiv.addEventListener('mouseover', mouseoverFunc({'image': 'no image found'}));
                    lastImageDiv.addEventListener('mousemove', mousemoveFunc);
                    lastImageDiv.addEventListener('mouseout', mouseoutFunc);
                }

                
            } else if (type == 'log') {
                let logDiv = document.getElementById("log-0-" + observatory);
                let fragment = document.createDocumentFragment();

                let log = message['log'];
                log.forEach(function(item, index, array) {
                    let logMessage = document.createElement('div'); // create a p tag
                    logMessage.classList.add('px-3'); // add a class
                    logMessage.classList.add('py-1.5'); // add a class
                    logMessage.classList.add('grid'); // add a class
                    logMessage.classList.add('grid-cols-3'); // add a class
                    
                    if (item['level'] == 'warning') {
                        logMessage.classList.add('text-yellow-500'); // add a class
                    } else if (item['level'] == 'error') {
                        logMessage.classList.add('text-red-500'); // add a class
                    }
                    logMessage.innerHTML = `<div class="col-span-1 proportional-nums tracking-wide">${item['datetime'].substring(10)}</div> <div class="col-span-2 italic">${item['message']}</div>`;

                    fragment.appendChild(logMessage);
                });
                logDiv.appendChild(fragment);

                let element = document.getElementById("log-" + observatory);
                if (element.classList.contains('underline') && log.length > 0) {
                    let div = document.getElementById("log-0-" + observatory)
                    div.scrollTop = div.scrollHeight;
                }

                if (scheduleLoadTime[observatory] < message['schedule_mtime']) {
                    scheduleLoadTime[observatory] = message['schedule_mtime'];
                    updateSchedule(observatory);
                }

            }
        }

   
        {% for observatory in observatories %}

            // connect to websockets
            if (window.location.protocol === "https:") {
                console.log("Website accessed via HTTPS");
                connectWebSocket('wss://' + window.location.host + '/ws/' + '{{observatory}}', '{{observatory}}', 'summary');
                connectWebSocket('wss://' + window.location.host + '/ws/log/' + '{{observatory}}', '{{observatory}}', 'log');
            } else {
                console.log("Website accessed via HTTP");
                connectWebSocket('ws://' + window.location.host + '/ws/' + '{{observatory}}', '{{observatory}}', 'summary');
                connectWebSocket('ws://' + window.location.host + '/ws/log/' + '{{observatory}}', '{{observatory}}', 'log');
            }

            scheduleLoadTime['{{observatory}}'] = new Date().getTime()/1000;

            // update schedule table
            updateSchedule('{{observatory}}');

            // update weather chart
            updateWeatherChart('{{observatory}}', update=false);

            // todo: move to websocket
            setInterval(function() {
                updateWeatherChart('{{observatory}}', update=true);
            }, 60000);
            
        {% endfor %}


        
    </script>

</body>
</html>