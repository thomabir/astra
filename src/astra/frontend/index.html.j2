                                    class="w-8 h-8 mb-2 text-gray-400 group-hover:text-white transition-colors">
                                    <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" />
                                    <path fill-rule="evenodd"
                                        d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 010-1.113zM17.25 12a5.25 5.25 0 11-10.5 0 5.25 5.25 0 0110.5 0z"
                                        clip-rule="evenodd" />
                                </svg>
                                <span class="text-sm font-medium">Start Watchdog</span>
                            </button>

                            {% if config['Camera'] %}
                            {% for camera in config['Camera'] %}
                            <button
                                class="flex flex-col items-center justify-center aspect-square p-4 rounded-md bg-gray-600/20 hover:bg-gray-600/40 text-gray-200 transition-colors duration-100 group"
                                onclick="coolCamera('{{camera['device_name']}}', '{{camera['temperature']}}')">

                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="w-8 h-8 mb-2 text-gray-400 group-hover:text-white transition-colors">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="m4.5 5.25 7.5 7.5 7.5-7.5m-15 6 7.5 7.5 7.5-7.5" />
                                </svg>
                                <span class="text-sm font-medium">Cool {{camera['device_name']}}</span>
                                <span class="text-xs text-gray-400 mt-1">to {{camera['temperature']}}°C</span>
                            </button>
                            {% endfor %}
                            {% endif %}

                            <button
                                class="flex flex-col items-center justify-center aspect-square p-4 rounded-md bg-gray-600/20 hover:bg-gray-600/40 text-gray-200 transition-colors duration-100 group"
                                onclick="completeHeaders()">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="w-8 h-8 mb-2 text-gray-400 group-hover:text-white transition-colors">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M6 6.878V6a2.25 2.25 0 0 1 2.25-2.25h7.5A2.25 2.25 0 0 1 18 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 0 0 4.5 9v.878m13.5-3A2.25 2.25 0 0 1 19.5 9v.878m0 0a2.246 2.246 0 0 0-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0 1 21 12v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6c0-.98.626-1.813 1.5-2.122" />
                                </svg>
                                <span class="text-sm font-medium">Complete Headers</span>
                            </button>

                        </div>
                    </div>

                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </div>



    <script>

        // log config
        console.log("config: ", {{ config | tojson }});

        // Modal Logic
        let confirmCallback = null;
        let cancelCallback = null;

        function showConfirmModal(message, onConfirm, onCancel = null) {
            const modal = document.getElementById('confirmModal');
            const messageEl = document.getElementById('confirmMessage');

            messageEl.textContent = message;
            confirmCallback = onConfirm;
            cancelCallback = onCancel;

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeConfirmModal() {
            const modal = document.getElementById('confirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            confirmCallback = null;
            cancelCallback = null;
        }

        document.getElementById('confirmOkBtn').addEventListener('click', () => {
            if (confirmCallback) confirmCallback();
            closeConfirmModal();
        });

        document.getElementById('confirmCancelBtn').addEventListener('click', () => {
            if (cancelCallback) cancelCallback();
            closeConfirmModal();
        });

        // Close on click outside
        document.getElementById('confirmModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('confirmModal')) {
                if (cancelCallback) cancelCallback();
                closeConfirmModal();
            }
        });

        particlesJS.load('particles-js', '/js/particlesjs-config.json', function () {
            console.log('callback - particles.js config loaded');
        });

        // Handle window resize for particles.js
        window.addEventListener('resize', function () {
            // Debounce resize events to avoid too many calls
            clearTimeout(window.resizeTimeout);
            window.resizeTimeout = setTimeout(function () {
                // Reload particles.js on resize
                particlesJS.load('particles-js', '/js/particlesjs-config.json');
            }, 100);
        });

        const popup = document.querySelector('#popup');

        let scheduleLoadTime = {}

        function movePopup(e) {
            const mouseX = e.pageX;
            const mouseY = e.pageY;
            const popupWidth = popup.offsetWidth;
            const popupHeight = popup.offsetHeight;
            const padding = 10;
            const popupX = mouseX + padding;
            const popupY = mouseY + padding;
            const maxX = window.innerWidth - popupWidth - padding;
            const maxY = window.innerHeight - popupHeight - padding;
            const adjustedX = Math.min(popupX, maxX);
            const adjustedY = popupY > maxY ? mouseY - popupHeight - padding : popupY;
            popup.style.left = `${adjustedX}px`;
            popup.style.top = `${adjustedY}px`;
        }

        function syntaxHighlight(json) {
            if (typeof json != 'string') {
                json = JSON.stringify(json, undefined, 2);
            }
            json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
                var cls = 'number';

                if (/^"/.test(match)) {
                    if (/:$/.test(match)) {
                        cls = 'key';
                    } else {
                        cls = 'string';
                        if (match == '"null"') {
                            cls += ' text-red-500 font-extrabold';
                        } else {
                            cls += ' text-blue-300 italic';
                        }
                    }
                } else if (/true|false/.test(match)) {
                    cls = 'boolean italic';
                    if (/true/.test(match)) {
                        cls += ' text-green-500/50';
                    } else if (/false/.test(match)) {
                        cls += ' text-red-500/50';
                    }
                } else if (/null/.test(match)) {
                    cls = 'null italic text-red-500';
                }

                if (cls == 'number') {
                    cls += ' italic text-blue-300'
                    match = parseFloat(match).toFixed(3);
                }

                match = match.replace(/"/g, ''); // remove quotes

                return '<span class="' + cls + '">' + match + '</span>';
            });
        }

        function escapeHtml(unsafe) {
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function navClick(element) {
            // element: the navigation element that was clicked

            // remove underline from other elements
            {% for nav in navigation %}
            document.getElementById("{{nav | lower}}").classList.remove("underline")
            {% endfor %}
            // underline the clicked element
            document.getElementById(element.id).classList.add("underline")

            // hide all content
            {% for nav in navigation %}
            document.getElementById("{{nav | lower}}-content").classList.add("hidden")
            {% endfor %}
            // show the content for the clicked element
            document.getElementById(element.id + "-content").classList.remove("hidden")

            let div = document.getElementById("content")
            if (element.id.split("--")[0] == 'log') {
                let divLog = document.getElementById("log-0" + "-parent");
                // Use setTimeout to ensure the content is fully rendered before scrolling
                setTimeout(() => {
                    divLog.scrollTop = divLog.scrollHeight;
                }, 0);
            } else {
                div.scrollTop = 0;
            }


        }

        function updateTable(tableId, data, headers, thead_display = true, right_align = true) {
            // tableId: id of the table to update
            // data: array of objects containing the data to be displayed
            // headers: object containing the headers for the table
            // thead_display: boolean, whether to display the table headers

            var table = document.getElementById(tableId);


            if (thead_display) {
                var thead = table.getElementsByTagName("thead")[0];
                thead.innerHTML = "";

                var row = thead.insertRow(0);
                row.classList.add("border-b-2");
                row.classList.add("border-b-slate-500");

                for (var i = 0; i < Object.keys(headers).length; i++) {
                    var cell = row.insertCell(i);
                    cell.innerHTML = Object.values(headers)[i];
                    cell.classList.add("py-1.5");
                    cell.classList.add("px-3");

                    // if last column, right align
                    if ((i == Object.keys(headers).length - 1) && right_align) {
                        cell.classList.add("text-right");
                    }
                }
            }

            var tbody = table.getElementsByTagName("tbody")[0];
            tbody.innerHTML = "";

            // create a new row for every item in data
            for (var i = 0; i < data.length; i++) {
                var row = tbody.insertRow(i);
                row.classList.add("border-b");
                row.classList.add("border-b-slate-500");
                row.classList.add("hover:bg-gray-600/40");
                row.classList.add("transition-colors");
                row.key = i;


                row.addEventListener('mouseover', (e) => {
                    popup.classList.remove('hidden');
                    popup.classList.add('block');
                    let text = syntaxHighlight(data[e.target.parentNode.key]);


                    // Split the text into lines
                    let lines = text.split('\n');

                    // Check if there are 10 or more lines
                    if (lines.length >= 10) {
                        // Split the lines into two groups for the columns
                        let mid = Math.ceil(lines.length / 2);
                        let firstColumn = lines.slice(0, mid).join('\n');
                        let secondColumn = lines.slice(mid).join('\n');

                        // Wrap the content in divs and add Tailwind classes
                        popup.innerHTML = `<div class="grid grid-cols-2 gap-8 align-top"><div>${firstColumn}</div><div>${secondColumn}</div></div>`;
                    } else {
                        // If less than 10 lines, just set the text
                        popup.innerHTML = text;
                    }
                    movePopup(e);
                });

                row.addEventListener('mousemove', (e) => {
                    movePopup(e);
                });

                row.addEventListener('mouseout', () => {
                    popup.classList.remove('block');
                    popup.classList.add('hidden');

                });

                row.addEventListener('click', (e) => {
                    // toggle
                    console.log("clicked")
                    if (popup.classList.contains('hidden')) {
                        popup.classList.remove('hidden');
                        popup.classList.add('block');
                    } else {
                        popup.classList.remove('block');
                        popup.classList.add('hidden');
                    }
                });

                for (var j = 0; j < Object.keys(headers).length; j++) {
                    var cell = row.insertCell(j);
                    cell.innerHTML = data[i][Object.keys(headers)[j]];
                    cell.classList.add("py-1.5");
                    cell.classList.add("px-3");


                    // if last column, right align and blue text
                    if ((j == Object.keys(headers).length - 1) && right_align) {
                        cell.classList.add("text-right");
                        cell.classList.add("text-blue-300");
                        cell.classList.add("font-variant-numeric");
                        cell.classList.add("proportional-nums");
                    }

                    // if status column, colour the cell
                    if (Object.keys(headers)[j] == "status") {
                        if (data[i]['valid'] == true) {
                            cell.classList.add("text-green-500");
                        } else if (data[i]['valid'] == false) {
                            cell.classList.add("text-red-500");
                        }
                    }
                }

            }
            row.classList.remove("border-b");
            row.classList.remove("border-b-slate-500");

        }

