        let mousePos = { x: 0, y: 0 };
        let weatherDataCache;
        let weatherLatestTimestamp;

        function updateWeatherLatestFromWebsocket(deviceData) {
            // Find ObservingConditions device data
            const weatherDevice = deviceData.find(device =>
                device.item === 'ObservingConditions' && device.polled
            );

            if (weatherDevice && weatherDataCache) {
                // Extract the latest values from the polled data
                const newLatest = {};
                for (const [key, value] of Object.entries(weatherDevice.polled)) {
                    if (key !== 'datetime' && value && typeof value.value !== 'undefined') {
                        newLatest[key] = parseFloat(value.value);
                    }
                }

                // Add calculated RelativeSkyTemp if both values exist
                if (newLatest.SkyTemperature && newLatest.Temperature) {
                    newLatest.RelativeSkyTemp = newLatest.SkyTemperature - newLatest.Temperature;
                }

                // Update the cached latest values
                weatherDataCache.latest = { ...weatherDataCache.latest, ...newLatest };
                // Update the weather table display without re-plotting charts
                updateWeatherTableOnly();
            }
        }

        function updateWeatherChart(update = false) {
            // On first load, fetch all data
            if (!weatherDataCache || !update) {
                fetch('/api/db/polling/ObservingConditions?day=3')
                    .then(response => response.json())
                    .then(data => {
                        weatherDataCache = data;
                        // Find latest timestamp
                        if (data.data && data.data.length > 0) {
                            weatherLatestTimestamp = data.data[data.data.length - 1].datetime;
                        }
                        plotWeather(data, update);
                    })
                    .then(() => {
                        // Only dispatch pointer events if weather tab is visible
                        const weatherTab = document.getElementById('weather-content');
                        if (weatherTab && !weatherTab.classList.contains('hidden')) {
                            const plots = document.querySelectorAll('div[id^="plot-"]');
                            plots.forEach((plot) => {
                                if (update == false) {
                                    plot.addEventListener("touchend", (event) => {
                                        const pointerleave = new PointerEvent("pointerleave", {
                                            bubbles: true,
                                            pointerType: "mouse",
                                        });
                                        event.target.dispatchEvent(pointerleave);
                                    });
                                    plot.addEventListener("pointermove", (event) => {
                                        const x = event.clientX;
                                        const y = event.clientY;
                                        mousePos = { x, y };
                                    });
                                } else {
                                    const plotDiv = plot.querySelector('svg');
                                    if (plotDiv) {
                                        const pointermove = new PointerEvent("pointermove", {
                                            bubbles: true,
                                            pointerType: "mouse",
                                            clientX: mousePos.x,
                                            clientY: mousePos.y,
                                        });
                                        plotDiv.dispatchEvent(pointermove);
                                    }
                                }
                            });
                        }
                    });
            } else {
                // On update, fetch only new data since last timestamp
                let since = weatherLatestTimestamp;
                // Ensure format is 'YYYY-MM-DD HH:MM:SS' (replace T with space if present)
                if (since && since.includes('T')) {
                    since = since.replace('T', ' ');
                }
                fetch('/api/db/polling/ObservingConditions?since=' + encodeURIComponent(since))
                    .then(response => response.json())
                    .then(newData => {
                        // Merge new data, replacing last point if overlapping (binned per minute)
                        if (newData.data && newData.data.length > 0) {
                            let cached = weatherDataCache.data;
                            let newFirst = newData.data[0];
                            if (cached.length > 0 && cached[cached.length - 1].datetime === newFirst.datetime) {
                                // Replace last cached point with new one
                                cached[cached.length - 1] = newFirst;
                                // Append any additional new points
                                if (newData.data.length > 1) {
                                    cached = cached.concat(newData.data.slice(1));
                                }
                                weatherDataCache.data = cached;
                            } else {
                                weatherDataCache.data = cached.concat(newData.data);
                            }
                            weatherDataCache.latest = newData.latest;
                            weatherDataCache.twilight_periods = newData.twilight_periods || [];
                            weatherLatestTimestamp = newData.data[newData.data.length - 1].datetime;
                        }
                        // Use merged data for plotting
                        plotWeather(weatherDataCache, update);
                    })
                    .then(() => {
                        // Only dispatch pointer events if weather tab is visible
                        const weatherTab = document.getElementById('weather-content');
                        if (weatherTab && !weatherTab.classList.contains('hidden')) {
                            const plots = document.querySelectorAll('div[id^="plot-"]');
                            plots.forEach((plot) => {
                                const plotDiv = plot.querySelector('svg');
                                if (plotDiv) {
                                    const pointermove = new PointerEvent("pointermove", {
                                        bubbles: true,
                                        pointerType: "mouse",
                                        clientX: mousePos.x,
                                        clientY: mousePos.y,
                                    });
                                    plotDiv.dispatchEvent(pointermove);
                                }
                            });
                        }
                    });
            }
        }

